# Hormuz Ship Tracker — credentials
# Copy this file to .env and fill in your keys.
# All services are free — see README.md for signup links.

# AIS live ship data (https://aisstream.io — sign in with GitHub)
AISSTREAM_API_KEY=

# Copernicus Data Space Ecosystem (https://dataspace.copernicus.eu)
CDSE_USER=
CDSE_PASSWORD=

# Sentinel Hub OAuth client (CDSE Dashboard → User Settings → OAuth Clients)
SH_CLIENT_ID=
SH_CLIENT_SECRET=


